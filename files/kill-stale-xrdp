#!/bin/sh
# Kill an xrdp process that holds the Xorg display socket but whose TCP
# connection to the client is backed up (Send-Q > 0), which indicates the
# client is unreachable — e.g. a Windows PC that went to sleep without
# cleanly disconnecting the RDP session.
# Called from reconnectwm.sh via sudo on every session reconnect.

display_num="$1"
[ -z "$display_num" ] && exit 0

# The display socket path is named on the Xorg side of the connection.
# Get its inode, then find the xrdp process whose peer inode matches.
display_inode=$(ss -Hxp 2>/dev/null \
    | awk -v sock="xrdp_display_${display_num}" '$5 ~ sock { print $6; exit }')

[ -z "$display_inode" ] && exit 0

xrdp_pid=$(ss -Hxp 2>/dev/null \
    | awk -v inode="$display_inode" \
        '$8 == inode { match($NF, /pid=([0-9]+)/, a); if (a[1]) print a[1]; exit }')

[ -z "$xrdp_pid" ] && exit 0

# Safety check: confirm it is actually an xrdp process.
case "$(ps -p "$xrdp_pid" -o args= 2>/dev/null)" in
    *xrdp*) : ;;
    *) exit 0 ;;
esac

# Safety check: if the process is less than 30 seconds old it is the current
# session's xrdp (which may have a briefly non-zero Send-Q during the initial
# display burst). Only a stale process from a sleeping client will be older.
elapsed=$(ps -p "$xrdp_pid" -o etimes= 2>/dev/null | tr -d ' ')
[ -z "$elapsed" ] && exit 0
[ "$elapsed" -lt 30 ] && exit 0

# Check the TCP Send-Q for this process. A non-zero Send-Q means data is
# queued but the client is not ACKing it — the session is stale.
send_q=$(ss -Htnp 2>/dev/null \
    | awk -v pid="pid=${xrdp_pid}," '$1=="ESTAB" && $NF ~ pid { print $3; exit }')

if [ -n "$send_q" ] && [ "$send_q" -gt 0 ] 2>/dev/null; then
    kill "$xrdp_pid"
fi
